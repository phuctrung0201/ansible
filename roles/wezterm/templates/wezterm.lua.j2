-- Ansible — Catppuccin Mocha/Macchiato mix. Mirrors roles/ghostty/templates/config.ghostty.j2.
local wezterm = require 'wezterm'
local config = wezterm.config_builder()

-- Theme colors (rendered by Ansible from share.yml)
local C = {
  bg       = '{{ theme.bg }}',
  fg       = '{{ theme.fg }}',
  surface0 = '{{ theme.surface0 }}',
  selection= '{{ theme.selection }}',
  comment  = '{{ theme.comment }}',
  cyan     = '{{ theme.cyan }}',
  green    = '{{ theme.green }}',
  purple   = '{{ theme.purple }}',
}

-- Font
config.font = wezterm.font('FiraCode Nerd Font Mono')
config.font_size = 16

-- Colors
config.colors = {
  foreground   = C.fg,
  background   = C.bg,
  selection_fg = C.fg,
  selection_bg = C.selection,
  cursor_bg    = C.cyan,
  cursor_fg    = C.bg,
  cursor_border= C.cyan,
  split        = C.cyan,
  ansi = {
    '{{ theme.dark }}',
    '{{ theme.red }}',
    '{{ theme.green }}',
    '{{ theme.yellow }}',
    '{{ theme.blue }}',
    '{{ theme.pink }}',
    '{{ theme.cyan }}',
    '{{ theme.white }}',
  },
  brights = {
    '{{ theme.comment_bright }}',
    '{{ theme.bright_red }}',
    '{{ theme.bright_green }}',
    '{{ theme.bright_yellow }}',
    '{{ theme.bright_purple }}',
    '{{ theme.bright_pink }}',
    '{{ theme.bright_cyan }}',
    '{{ theme.bright_white }}',
  },
  tab_bar = {
    background    = 'rgba(0,0,0,0)',
    active_tab    = { bg_color = 'rgba(0,0,0,0)', fg_color = 'rgba(0,0,0,0)' },
    inactive_tab  = { bg_color = 'rgba(0,0,0,0)', fg_color = 'rgba(0,0,0,0)' },
    inactive_tab_hover = { bg_color = 'rgba(0,0,0,0)', fg_color = 'rgba(0,0,0,0)' },
    new_tab       = { bg_color = 'rgba(0,0,0,0)', fg_color = 'rgba(0,0,0,0)' },
    new_tab_hover = { bg_color = 'rgba(0,0,0,0)', fg_color = 'rgba(0,0,0,0)' },
  },
}

-- Cursor
config.default_cursor_style = 'SteadyBar'

-- macOS: Option sends Alt (Neovim/Snacks <a-h> / <a-i>)
config.send_composed_key_when_left_alt_is_pressed = false
config.send_composed_key_when_right_alt_is_pressed = false

-- Window — hidden titlebar, opacity/blur matching Ghostty
config.window_background_opacity = 0.65
config.macos_window_background_blur = 20
config.window_decorations = 'RESIZE'
config.window_padding = { left = 0, right = 0, top = 0, bottom = 0 }

-- Helper: basename of pane's cwd
local function cwd_basename(pane)
  local uri = pane:get_current_working_dir()
  if not uri then return nil end
  local path = type(uri) == 'string' and uri or uri.file_path
  return path:match('([^/]+)/?$')
end

-- Keys
config.keys = {
  { key = 'p', mods = 'ALT', action = wezterm.action.ActivateCommandPalette },
  { key = '\\', mods = 'ALT', action = wezterm.action.InputSelector {
    title = ' helper ',
    alphabet = 'damsvcx',
    choices = {
      { label = 'rename workspace to cwd', id = 'workspace-cwd' },
      { label = 'rename tab to agent',     id = 'tab-agent' },
      { label = 'rename tab to markserve', id = 'tab-markserve' },
      { label = 'split horizontal',        id = 'split' },
      { label = 'split vertical',          id = 'vsplit' },
      { label = 'activate copy mode',      id = 'copy-mode' },
      { label = 'close pane',              id = 'close-pane' },
    },
    action = wezterm.action_callback(function(window, pane, id, _label)
      if not id then return end
      if id == 'workspace-cwd' then
        local name = cwd_basename(pane)
        if name then wezterm.mux.rename_workspace(window:active_workspace(), name) end
      elseif id == 'tab-agent' then
        window:active_tab():set_title('agent')
      elseif id == 'tab-markserve' then
        window:active_tab():set_title('markserve')
      elseif id == 'split' then
        pane:split { direction = 'Right' }
      elseif id == 'vsplit' then
        pane:split { direction = 'Bottom' }
      elseif id == 'copy-mode' then
        window:perform_action(wezterm.action.ActivateCopyMode, pane)
      elseif id == 'close-pane' then
        window:perform_action(wezterm.action.CloseCurrentPane { confirm = false }, pane)
      end
    end),
  } },
}

-- Tab bar — retro, positioned at top; tabs hidden (status bar kept for left status)
config.use_fancy_tab_bar = false
config.tab_bar_at_bottom = true
config.hide_tab_bar_if_only_one_tab = false
config.show_new_tab_button_in_tab_bar = false

-- Powerline arrows
local L = wezterm.nerdfonts.pl_right_hard_divider  --
local R = wezterm.nerdfonts.pl_left_hard_divider   --

-- Left: [tab/pane name]   Right: [workspace] < [mode]
wezterm.on('update-right-status', function(window, pane)
  local tab = window:mux_window():active_tab()
  local tab_title = tab:get_title()
  if not tab_title or tab_title == '' then
    tab_title = pane:get_title()
  end
  local workspace = window:active_workspace()

  local mode_color, mode_text
  if window:active_key_table() == 'copy_mode' then
    mode_color, mode_text = C.purple, 'COPY'
  else
    mode_color, mode_text = C.green, 'SHELL'
  end

  window:set_right_status('')
  window:set_left_status(wezterm.format({
    -- mode pill
    { Background = { Color = mode_color } },
    { Foreground = { Color = C.bg } },
    { Attribute = { Intensity = 'Bold' } },
    { Text = ' ' .. mode_text .. ' ' },
    -- mode_color → surface0
    { Background = { Color = C.surface0 } },
    { Foreground = { Color = mode_color } },
    { Text = R },
    -- workspace
    { Background = { Color = C.surface0 } },
    { Foreground = { Color = mode_color } },
    { Attribute = { Intensity = 'Normal' } },
    { Text = ' 󰽘 ' .. workspace .. ' ' },
    -- surface0 → transparent
    { Background = { Color = 'rgba(0,0,0,0)' } },
    { Foreground = { Color = C.surface0 } },
    { Text = R },
    -- tab/pane name
    { Background = { Color = 'rgba(0,0,0,0)' } },
    { Foreground = { Color = C.fg } },
    { Text = ' ' .. tab_title .. ' ' },
  }))
end)

return config
