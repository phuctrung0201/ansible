-- Ansible — Catppuccin Mocha/Macchiato mix.

local wezterm = require('wezterm')
local act = wezterm.action

local config = wezterm.config_builder()

local bg = '{{ theme.bg }}'
local fg = '{{ theme.fg }}'
local comment = '{{ theme.comment }}'
local selection = '{{ theme.selection }}'
local green = '{{ theme.green }}'

-- Font
config.font = wezterm.font('FiraCode Nerd Font Mono')
config.font_size = 16.0

-- Colors
config.colors = {
  foreground = fg,
  background = bg,
  cursor_bg = '{{ theme.cyan }}',
  cursor_fg = bg,
  selection_bg = selection,
  selection_fg = fg,
  ansi = {
    '{{ theme.dark }}',
    '{{ theme.red }}',
    '{{ theme.green }}',
    '{{ theme.yellow }}',
    '{{ theme.blue }}',
    '{{ theme.pink }}',
    '{{ theme.cyan }}',
    '{{ theme.white }}',
  },
  brights = {
    '{{ theme.comment_bright }}',
    '{{ theme.bright_red }}',
    '{{ theme.bright_green }}',
    '{{ theme.bright_yellow }}',
    '{{ theme.bright_purple }}',
    '{{ theme.bright_pink }}',
    '{{ theme.bright_cyan }}',
    '{{ theme.bright_white }}',
  },
  -- Tab bar — solid backgrounds (stable rendering)
  tab_bar = {
    background = bg,
    active_tab = {
      bg_color = bg,
      fg_color = fg,
      intensity = 'Bold',
    },
    inactive_tab = {
      bg_color = bg,
      fg_color = comment,
    },
    inactive_tab_hover = {
      bg_color = bg,
      fg_color = fg,
    },
    new_tab = {
      bg_color = bg,
      fg_color = comment,
    },
    new_tab_hover = {
      bg_color = bg,
      fg_color = fg,
    },
    inactive_tab_edge = bg,
  },
}

-- Cursor
config.default_cursor_style = 'BlinkingBar'

-- Window — OpenGL default; no opacity/blur (stable rendering)
config.term = "xterm-256color"
config.window_decorations = 'RESIZE'
config.front_end = "OpenGL"
config.window_frame = {
  active_titlebar_bg = bg,
  inactive_titlebar_bg = bg,
}
config.window_padding = {
  left = 0,
  right = 0,
  top = '0.5cell',
  bottom = 0,
}

config.enable_tab_bar = true
config.use_fancy_tab_bar = false
config.tab_bar_at_bottom = true
config.show_new_tab_button_in_tab_bar = false
config.hide_tab_bar_if_only_one_tab = false

-- Persistent local mux — workspaces survive GUI restarts; extra GUIs can show other workspaces.
config.unix_domains = {
  {
    name = 'unix',
  },
}
config.default_gui_startup_args = { 'connect', 'unix' }

-- Homebrew bins (wezterm cli, lpass) — launch env omits /opt/homebrew/bin when started from Dock
local path = os.getenv('PATH') or ''
config.set_environment_variables = {
  PATH = path .. ':/opt/homebrew/bin:/usr/local/bin',
}

-- Custom palette entries (Tab/Pane/Credential) in the built-in command palette
local palette = dofile((os.getenv('HOME') or '') .. '/.config/wezterm/palette.lua')
wezterm.on('augment-command-palette', function(window, pane)
  return palette.build_entries(window, pane)
end)

wezterm.on('update-status', function(window, _pane)
  local mux_win = window:mux_window()
  if not mux_win then
    return
  end
  local workspace = mux_win:get_workspace()
  if not workspace or workspace == '' then
    return
  end

  window:set_left_status(wezterm.format {
    { Text = ' ' },
    { Foreground = { Color = green } },
    { Attribute = { Intensity = 'Bold' } },
    { Text = wezterm.nerdfonts.md_layers .. ': ' .. workspace },
  })
end)

config.keys = {
  -- Cmd+W — close the current pane (instead of the whole tab)
  {
    key = 'w',
    mods = 'CMD',
    action = act.CloseCurrentPane { confirm = true },
  },
  {
    key = 'w',
    mods = 'CMD|SHIFT',
    action = act.DetachDomain 'CurrentPaneDomain',
  },
  -- Cmd+N — attach a new GUI window to the current mux workspace (overrides SpawnWindow)
  {
    key = 'n',
    mods = 'CMD',
    action = wezterm.action_callback(function(window, _pane)
      palette.attach_current_workspace_window(window)
    end),
  },
  -- Command palette (Ctrl+Shift+P is the WezTerm default)
  {
    key = ' ',
    mods = 'ALT',
    action = act.ActivateCommandPalette,
  },
  {
    key = 's',
    mods = 'ALT',
    action = act.QuickSelect,
  },
}

return config
