{# Window borders — colors from share.yml (same pairing as Ghostty active/inactive borders). #}
{% set _border_active = theme.cyan | replace("#", "") | upper %}
{% set _border_inactive = theme.comment_bright | replace("#", "") | upper %}
after-login-command = []

after-startup-command = [
'exec-and-forget borders active_color=0xCC{{ _border_active }} inactive_color=0x40{{ _border_inactive }} width=5.0'
]

# Start AeroSpace at login
start-at-login = true

# Normalizations. See: https://nikitabobko.github.io/AeroSpace/guide#normalization
enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

# You can set 0 to disable the padding feature
accordion-padding = 30

# Possible values: tiles|accordion
default-root-container-layout = 'tiles'

# 'auto' means: wide monitor (anything wider than high) gets horizontal orientation,
#               tall monitor (anything higher than wide) gets vertical orientation
default-root-container-orientation = 'auto'
# Mouse follows focused monitor (see https://nikitabobko.github.io/AeroSpace/commands#move-mouse)
on-focused-monitor-changed = ['move-mouse monitor-lazy-center']
# Mouse follows focused window or workspace when focus changes
on-focus-changed = ['move-mouse window-lazy-center']
automatically-unhide-macos-hidden-apps = false

# Run when the focused workspace changes. Doc pattern: https://nikitabobko.github.io/AeroSpace/guide#exec-on-workspace-change-callback
# Same shape as the SketchyBar example: /bin/bash -c "<script>" (argv0 is not resolved via PATH; the shell finds im-select).
# Env: AEROSPACE_FOCUSED_WORKSPACE, AEROSPACE_PREV_WORKSPACE. English layout id: run `im-select` with no args to print current.
# No [exec] block: AeroSpace defaults already prepend /opt/homebrew to PATH for exec-* (guide §2.7). Add [exec.env-vars] only for Intel Homebrew (/usr/local), ~/bin, etc.
exec-on-workspace-change = ['/bin/bash', '-c', 'im-select com.apple.keylayout.ABC']

[key-mapping]
preset = 'qwerty'
[gaps]
inner.horizontal = 8
inner.vertical = 8
outer.left = 4
outer.bottom = 4
outer.top = 4
outer.right = 4

# Main mode is passive — all keys pass through to apps.
# f11 toggles action mode (see f11 in [mode.action.binding]).
[mode.main.binding]
f11 = 'mode action'

# Action mode — persistent window management.
# Workspaces: `=terminal 1=browser 2=fallback 3=empty F1=slack F2=outlook F3=zoom
[mode.action.binding]
f11 = 'mode main'

# space: previous ↔ current window; tab: next window in workspace (DFS order, wraps)
tab = ['focus --boundaries-action wrap-around-the-workspace dfs-next', 'mode main']
backtick = ['workspace --auto-back-and-forth `', 'mode main']
shift-backtick = ['move-node-to-workspace --focus-follows-window `', 'mode main']
space = ['focus-back-and-forth', 'mode main']
shift-space = 'workspace --wrap-around next'

# Focus (hjkl)
h = 'focus left'
j = 'focus down'
k = 'focus up'
l = 'focus right'

# Move windows (shift-hjkl)
shift-h = 'move left'
shift-j = 'move down'
shift-k = 'move up'
shift-l = 'move right'

# Workspaces
1 = ['workspace 1', 'mode main']
2 = ['workspace 2', 'mode main']
3 = ['workspace 3', 'mode main']
f3 = ['workspace F3', 'mode main']
f2 = ['workspace F2', 'mode main']
f1 = ['workspace F1', 'mode main']
shift-1 = 'move-node-to-workspace --focus-follows-window 1'
shift-2 = 'move-node-to-workspace --focus-follows-window 2'
shift-3 = 'move-node-to-workspace --focus-follows-window 3'
shift-f3 = 'move-node-to-workspace --focus-follows-window F3'
shift-f2 = 'move-node-to-workspace --focus-follows-window F2'
shift-f1 = 'move-node-to-workspace --focus-follows-window F1'

# Monitor (brackets)
leftSquareBracket = ['focus-monitor --wrap-around prev', 'mode main']
rightSquareBracket = ['focus-monitor --wrap-around next', 'mode main']
shift-leftSquareBracket = 'move-workspace-to-monitor --wrap-around prev'
shift-rightSquareBracket = 'move-workspace-to-monitor --wrap-around next'

# Layout
t = ['layout accordion tiles', 'mode main']
f = ['layout floating tiling', 'mode main']

# Resize
minus = ['resize smart -50', 'mode main']
equal = ['resize smart +50', 'mode main']

# Service
r = ['reload-config', 'mode main']
x = 'close'
shift-x = ['close-all-windows-but-current', 'mode main']

esc = 'mode main'

# List current opening apps
# aerospace list-apps
[[on-window-detected]]
if.app-id = 'com.mitchellh.ghostty'
run = 'move-node-to-workspace --focus-follows-window `'

[[on-window-detected]]
if.app-id = 'app.zen-browser.zen'
run = 'move-node-to-workspace --focus-follows-window 1'

[[on-window-detected]]
if.app-id = 'com.tinyspeck.slackmacgap'
run = 'move-node-to-workspace --focus-follows-window F1'

[[on-window-detected]]
if.app-id = 'com.microsoft.Outlook'
run = 'move-node-to-workspace --focus-follows-window F2'

[[on-window-detected]]
if.app-id = 'us.zoom.xos'
run = 'move-node-to-workspace --focus-follows-window F3'

[[on-window-detected]]
check-further-callbacks = true
run = 'move-node-to-workspace --focus-follows-window 2'
