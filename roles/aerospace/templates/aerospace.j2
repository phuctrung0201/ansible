{# Window borders — colors from share.yml (same pairing as Ghostty active/inactive borders). #}
{% set _border_active = theme.purple | replace("#", "") | upper %}
{% set _border_inactive = theme.comment_bright | replace("#", "") | upper %}
after-login-command = []

after-startup-command = [
'exec-and-forget borders active_color=0xCC{{ _border_active }} inactive_color=0x30{{ _border_inactive }} width=3.0'
]

# Start AeroSpace at login
start-at-login = true

# Normalizations. See: https://nikitabobko.github.io/AeroSpace/guide#normalization
enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

# You can set 0 to disable the padding feature
accordion-padding = 30

# Possible values: tiles|accordion
default-root-container-layout = 'tiles'

# Run when the focused workspace changes. Doc pattern: https://nikitabobko.github.io/AeroSpace/guide#exec-on-workspace-change-callback
# Same shape as the SketchyBar example: /bin/bash -c "<script>" (argv0 is not resolved via PATH; the shell finds im-select).
# Env: AEROSPACE_FOCUSED_WORKSPACE, AEROSPACE_PREV_WORKSPACE. English layout id: run `im-select` with no args to print current.
# No [exec] block: AeroSpace defaults already prepend /opt/homebrew to PATH for exec-* (guide §2.7). Add [exec.env-vars] only for Intel Homebrew (/usr/local), ~/bin, etc.
exec-on-workspace-change = ['/bin/bash', '-c', 'im-select com.apple.keylayout.ABC']

[key-mapping]
preset = 'qwerty'

# Pin workspaces to monitors by index (1 = main, 2 = secondary).
[workspace-to-monitor-force-assignment]
F1 = 1
F2 = 2

[gaps]
inner.horizontal = 8
inner.vertical = 8
outer.left = 4
outer.bottom = 4
outer.top = 4
outer.right = 4

# Window management: Option (⌥) + key. On macOS, AeroSpace's `alt-` prefix is the Option key.
# No separate binding mode — chords run directly from main mode.
# Workspaces: 1=terminal+obsidian 2=browser 3=fallback F1=screen 1 F2=screen 2
[mode.main.binding]

# tab/backslash in the old action mode → Option+key
alt-backslash = 'focus-monitor --wrap-around next'
alt-shift-backslash = 'move-workspace-to-monitor --wrap-around next'
alt-tab = 'workspace next --wrap-around'
alt-shift-tab = 'move-node-to-workspace --focus-follows-window --wrap-around next'

alt-backtick = 'workspace-back-and-forth'

# Focus (hjkl — left/down/up/right)
alt-h = 'focus left'
alt-j = 'focus down'
alt-k = 'focus up'
alt-l = 'focus right'

# Move windows (Option+Shift+aswd)
alt-shift-h = 'move left'
alt-shift-j = 'move down'
alt-shift-k = 'move up'
alt-shift-l = 'move right'

# Workspaces
alt-1 = 'summon-workspace 1'
alt-2 = 'summon-workspace 2'
alt-3 = 'summon-workspace 3'
alt-f2 = 'workspace F2'
alt-f1 = 'workspace F1'
alt-shift-1 = 'move-node-to-workspace --focus-follows-window 1'
alt-shift-2 = 'move-node-to-workspace --focus-follows-window 2'
alt-shift-3 = 'move-node-to-workspace --focus-follows-window 3'
alt-shift-f1 = 'move-node-to-workspace --focus-follows-window F1'
alt-shift-f2 = 'move-node-to-workspace --focus-follows-window F2'

# Window focus (brackets)
alt-leftSquareBracket = 'focus dfs-prev'
alt-rightSquareBracket = 'focus dfs-next'

# Layout
alt-t = 'layout accordion tiles'
alt-f = 'layout floating tiling'

# Resize
alt-minus = 'resize smart -50'
alt-equal = 'resize smart +50'

# Service
alt-r = 'reload-config'
alt-x = 'close'
alt-shift-x = 'close-all-windows-but-current'

# List current opening apps
# aerospace list-apps
[[on-window-detected]]
if.app-id = 'com.github.wez.wezterm'
run = 'move-node-to-workspace --focus-follows-window 1'

[[on-window-detected]]
if.app-id = 'app.zen-browser.zen'
run = 'move-node-to-workspace --focus-follows-window 2'

[[on-window-detected]]
if.app-id = 'md.obsidian'
run = 'move-node-to-workspace --focus-follows-window 1'

[[on-window-detected]]
check-further-callbacks = true
run = 'move-node-to-workspace --focus-follows-window 3'
