after-login-command = []

after-startup-command = [
'exec-and-forget borders active_color=0xFFBD93F9 inactive_color=0xFF44475A width=5.0'
]

# Start AeroSpace at login
start-at-login = true

# Normalizations. See: https://nikitabobko.github.io/AeroSpace/guide#normalization
enable-normalization-flatten-containers = true
enable-normalization-opposite-orientation-for-nested-containers = true

# You can set 0 to disable the padding feature
accordion-padding = 30

# Possible values: tiles|accordion
default-root-container-layout = 'tiles'

# 'auto' means: wide monitor (anything wider than high) gets horizontal orientation,
#               tall monitor (anything higher than wide) gets vertical orientation
default-root-container-orientation = 'auto'
on-focused-monitor-changed = []
on-focus-changed = []
automatically-unhide-macos-hidden-apps = false
[key-mapping]
preset = 'qwerty'
[gaps]
inner.horizontal = 8
inner.vertical = 8
outer.left = 4
outer.bottom = 4
outer.top = 4
outer.right = 4

# Main mode is passive — all keys pass through to apps.
# alt-space enters leader mode (one-shot: action then back to main).
# Press space in leader mode to switch to action mode (persistent).
[mode.main.binding]
alt-space = 'mode leader'

# Leader mode — one-shot window management. Every action returns to main.
# Press space to switch to action mode for chaining commands.
[mode.leader.binding]

space = 'mode action'

# Focus (hjkl)
h = ['focus left', 'mode main']
j = ['focus down', 'mode main']
k = ['focus up', 'mode main']
l = ['focus right', 'mode main']

# Move windows (shift-hjkl)
shift-h = ['move left', 'mode main']
shift-j = ['move down', 'mode main']
shift-k = ['move up', 'mode main']
shift-l = ['move right', 'mode main']

# Workspaces (number keys)
1 = ['workspace 1', 'mode main']
2 = ['workspace 2', 'mode main']
3 = ['workspace 3', 'mode main']
4 = ['workspace 4', 'mode main']
shift-1 = ['move-node-to-workspace --focus-follows-window 1', 'mode main']
shift-2 = ['move-node-to-workspace --focus-follows-window 2', 'mode main']
shift-3 = ['move-node-to-workspace --focus-follows-window 3', 'mode main']
shift-4 = ['move-node-to-workspace --focus-follows-window 4', 'mode main']
backslash = ['workspace --auto-back-and-forth \', 'mode main']
shift-backslash = ['move-node-to-workspace --focus-follows-window \', 'mode main']

# Monitor (brackets)
leftSquareBracket = ['focus-monitor --wrap-around prev', 'mode main']
rightSquareBracket = ['focus-monitor --wrap-around next', 'mode main']
shift-leftSquareBracket = ['move-workspace-to-monitor --wrap-around prev', 'mode main']
shift-rightSquareBracket = ['move-workspace-to-monitor --wrap-around next', 'mode main']

# Layout
t = ['layout accordion tiles', 'mode main']
f = ['layout floating tiling', 'mode main']
tab = ['focus-back-and-forth', 'mode main']
e = ['flatten-workspace-tree', 'mode main']

# Resize
minus = ['resize smart -50', 'mode main']
equal = ['resize smart +50', 'mode main']

# Service
r = ['reload-config', 'mode main']
x = ['close', 'mode main']
shift-x = ['close-all-windows-but-current', 'mode main']

esc = 'mode main'

# Action mode — persistent window management for chaining commands.
# Press space to toggle back to leader mode, esc to exit to main.
[mode.action.binding]

space = 'mode leader'

# Focus (hjkl)
h = 'focus left'
j = 'focus down'
k = 'focus up'
l = 'focus right'

# Move windows (shift-hjkl)
shift-h = 'move left'
shift-j = 'move down'
shift-k = 'move up'
shift-l = 'move right'

# Workspaces (number keys)
1 = 'workspace 1'
2 = 'workspace 2'
3 = 'workspace 3'
4 = 'workspace 4'
shift-1 = 'move-node-to-workspace --focus-follows-window 1'
shift-2 = 'move-node-to-workspace --focus-follows-window 2'
shift-3 = 'move-node-to-workspace --focus-follows-window 3'
shift-4 = 'move-node-to-workspace --focus-follows-window 4'
backslash = 'workspace --auto-back-and-forth \'
shift-backslash = 'move-node-to-workspace --focus-follows-window \'

# Monitor (brackets)
leftSquareBracket = 'focus-monitor --wrap-around prev'
rightSquareBracket = 'focus-monitor --wrap-around next'
shift-leftSquareBracket = 'move-workspace-to-monitor --wrap-around prev'
shift-rightSquareBracket = 'move-workspace-to-monitor --wrap-around next'

# Layout
t = 'layout accordion tiles'
f = 'layout floating tiling'
tab = 'focus-back-and-forth'
e = 'flatten-workspace-tree'

# Resize
minus = 'resize smart -50'
equal = 'resize smart +50'

# Service
r = 'reload-config'
x = 'close'
shift-x = 'close-all-windows-but-current'

esc = 'mode main'

# List current opening apps
# aerospace list-apps
[[on-window-detected]]
if.app-id = 'app.zen-browser.zen'
run = 'move-node-to-workspace --focus-follows-window 1'

[[on-window-detected]]
if.app-id = 'net.kovidgoyal.kitty'
run = 'move-node-to-workspace --focus-follows-window \'

[[on-window-detected]]
if.app-id = 'com.tinyspeck.slackmacgap'
run = 'move-node-to-workspace --focus-follows-window 2'

[[on-window-detected]]
if.app-id = 'us.zoom.xos'
run = 'move-node-to-workspace --focus-follows-window 3'

[[on-window-detected]]
check-further-callbacks = true
run = 'move-node-to-workspace --focus-follows-window 4'
