# =============================================================================
# Font
# =============================================================================
font-family = FiraCode Nerd Font Mono
font-size = 16
font-thicken = true

# =============================================================================
# Color scheme (Catppuccin Mocha)
# =============================================================================
foreground = {{ theme.fg }}
background = {{ theme.bg }}
selection-foreground = {{ theme.bg }}
selection-background = {{ theme.rosewater }}

cursor-color = {{ theme.rosewater }}
cursor-text = {{ theme.bg }}
cursor-style = bar

# Normal colors
palette = 0={{ theme.dark }}
palette = 1={{ theme.red }}
palette = 2={{ theme.green }}
palette = 3={{ theme.yellow }}
palette = 4={{ theme.blue }}
palette = 5={{ theme.pink }}
palette = 6={{ theme.cyan }}
palette = 7={{ theme.white }}

# Bright colors
palette = 8={{ theme.comment_bright }}
palette = 9={{ theme.bright_red }}
palette = 10={{ theme.bright_green }}
palette = 11={{ theme.bright_yellow }}
palette = 12={{ theme.blue }}
palette = 13={{ theme.bright_pink }}
palette = 14={{ theme.bright_cyan }}
palette = 15={{ theme.fg }}

# =============================================================================
# Window
# =============================================================================
window-decoration = true
macos-titlebar-style = hidden
background-opacity = 0.70
background-blur-radius = 25
window-padding-x = 8
window-padding-y = 8

# =============================================================================
# Key mappings
# =============================================================================
keybind = opt+space=text:\x02\x20
