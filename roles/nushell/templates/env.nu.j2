# env.nu — managed by Ansible nushell role

export-env {
    $env.EDITOR = "nvim"
    $env.PAGER = "bat"

    $env.CARAPACE_BRIDGES = "zsh,fish,bash,inshellisense"

    mut path_dirs = [
        $"($env.HOME)/.local/bin"
        $"($env.HOME)/.config/carapace/bin"
        "{{ nushell_brew_prefix.stdout | trim }}/bin"
    ]
    $env.PATH = ($path_dirs | append $env.PATH)
}
