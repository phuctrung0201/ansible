# .zshrc — managed by Ansible zsh role

# Homebrew prefix (Apple Silicon vs Intel)
if [[ -x /opt/homebrew/bin/brew ]]; then
  BREW_PREFIX="/opt/homebrew"
elif [[ -x /usr/local/bin/brew ]]; then
  BREW_PREFIX="/usr/local"
else
  BREW_PREFIX="{{ zsh_brew_prefix.stdout | trim }}"
fi

# PATH
path=(
  "$HOME/.local/bin"
  "$BREW_PREFIX/bin"
  $path
)
export PATH

# Editor and pager
export EDITOR="nvim"
export PAGER="bat"
export LPASS_AGENT_TIMEOUT="0"

# ls colors — native BSD/GNU ls (no oh-my-zsh)
if [[ "$OSTYPE" == darwin* ]]; then
  export CLICOLOR=1
  # Pairs: dir symlink socket pipe exe block char setuid setgid sticky other-writable
  export LSCOLORS="Exgxfxdxbxegedabagacad"
fi

# History
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt extended_history share_history inc_append_history hist_ignore_all_dups

# Vi mode (Esc → normal mode)
bindkey -v

# Completion
fpath=(
  "$BREW_PREFIX/share/zsh/site-functions"
  "$BREW_PREFIX/share/zsh-completions"
  $fpath
)
autoload -Uz compinit
compinit -C
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# Plugins — autosuggestions before syntax-highlighting (must be last)
source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=240'

source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# mise (version manager)
eval "$("$BREW_PREFIX/bin/mise" activate zsh)"

# zoxide (directory jumping)
eval "$(zoxide init zsh)"

# fzf (history / file / cd pickers)
source "$HOME/.config/fzf/fzf.zsh"

# Ctrl+e → edit command in $EDITOR
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey -M viins '\C-e' edit-command-line
bindkey -M vicmd '\C-e' edit-command-line

# LastPass (flpass command + shared picker script for tmux palette)
source "$HOME/.config/zsh/lpass.zsh"

# Starship prompt
eval "$(starship init zsh)"
