# starship.toml — managed by Ansible zsh role
# Palette from share.yml (Catppuccin Mocha / Macchiato mix)

palette = "catppuccin"

[palettes.catppuccin]
bg = "{{ theme.bg }}"
fg = "{{ theme.fg }}"
red = "{{ theme.red }}"
orange = "{{ theme.orange }}"
yellow = "{{ theme.yellow }}"
green = "{{ theme.green }}"
blue = "{{ theme.blue }}"
purple = "{{ theme.purple }}"
cyan = "{{ theme.cyan }}"
pink = "{{ theme.pink }}"
comment = "{{ theme.comment }}"
surface = "{{ theme.surface0 }}"

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_state\
$git_status\
$cmd_duration\
$line_break\
$character"""

[character]
success_symbol = "[❯](purple)"
error_symbol = "[❯](red)"
vimcmd_symbol = "[❮](yellow)"

[directory]
style = "fg:blue"
truncation_length = 4
truncate_to_repo = true

[git_branch]
style = "fg:purple"

[git_status]
style = "fg:yellow"

[cmd_duration]
min_time = 2000
style = "fg:comment"

[username]
style_user = "fg:green"
show_always = false

[hostname]
ssh_only = true
style = "fg:comment"
