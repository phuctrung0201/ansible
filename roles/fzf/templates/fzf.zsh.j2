# fzf shell integration
source <(fzf --zsh)


_fe_git() {
  local cmd
  cmd=$(printf "add\nunstage\nrestore\ncheckout\nlog\ndiff\nfetch" | \
    fzf --prompt=" git > " --layout=reverse --height=40%) || return
  case "$cmd" in
    add)
      local files
      files=$(git diff --name-only | \
        fzf --prompt="Add > " \
            --layout=reverse \
            --height=60% \
            --multi \
            --preview='git diff --color=always -- {}' \
            --preview-window=right:60%) || return
      echo "$files" | xargs git add
      ;;
    unstage)
      local files
      files=$(git diff --name-only --cached | \
        fzf --prompt="Unstage > " \
            --layout=reverse \
            --height=60% \
            --multi \
            --preview='git diff --cached --color=always -- {}' \
            --preview-window=right:60%) || return
      echo "$files" | xargs git restore --staged
      ;;
    restore)
      local files
      files=$(git diff --name-only | \
        fzf --prompt="Restore > " \
            --layout=reverse \
            --height=60% \
            --multi \
            --preview='git diff --color=always -- {}' \
            --preview-window=right:60%) || return
      echo "$files" | xargs git restore
      ;;
    checkout)
      local branch
      branch=$(git branch | sed 's/^\* //; s/^  //' | \
        fzf --prompt="Checkout > " --layout=reverse --height=40%) || return
      git checkout "$branch"
      ;;
    log)
      git log --oneline | \
        fzf --prompt="Commit > " \
            --layout=reverse \
            --height=60% \
            --preview='git show --stat --color=always {1}'
      ;;
    diff)
      git diff --name-only | \
        fzf --prompt="Diff > " \
            --layout=reverse \
            --height=60% \
            --preview='git diff --color=always {}'
      ;;
    fetch)
      local remote branch
      remote=$(git remote | fzf --prompt="Remote > " --layout=reverse --height=40%) || return
      branch=$(git ls-remote --heads "$remote" | awk '{print $2}' | sed 's|refs/heads/||' | \
        fzf --prompt="Branch > " --layout=reverse --height=40%) || return
      git fetch "$remote" "$branch"
      if ! git branch | grep -q "^\s*$branch$"; then
        git checkout -b "$branch" --track "$remote/$branch"
      fi
      ;;
  esac
}

_fe_kube() {
  local cmd
  cmd=$(printf "context\nnamespace\npods\nlogs\nconfigmap\ndeployment\nsecret" | \
    fzf --prompt="󱃾 kube > " --layout=reverse --height=40%) || return
  case "$cmd" in
    context)
      local current selected
      current=$(kubectl config current-context 2>/dev/null)
      selected=$(kubectl config get-contexts -o name | \
        fzf --prompt="Context > " \
            --layout=reverse \
            --height=40% \
            --header="current: ${current}") || return
      kubectl config use-context "$selected"
      ;;
    namespace)
      local current selected
      current=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null)
      selected=$(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | \
        fzf --prompt="Namespace > " \
            --layout=reverse \
            --height=40% \
            --header="current: ${current:-default}") || return
      kubectl config set-context --current --namespace="$selected"
      ;;
    pods)
      local pod
      pod=$(kubectl get pods | \
        fzf --prompt="Pod > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      kubectl get pod "$(echo "$pod" | awk '{print $1}')" -o yaml | bat --color=always --style=plain --paging=never --language=yaml
      ;;
    logs)
      local pod
      pod=$(kubectl get pods | \
        fzf --prompt="Pod > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      kubectl logs -f "$(echo "$pod" | awk '{print $1}')"
      ;;
    configmap)
      local cm
      cm=$(kubectl get configmaps | \
        fzf --prompt="ConfigMap > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      kubectl get configmap "$(echo "$cm" | awk '{print $1}')" -o yaml | bat --color=always --style=plain --paging=never --language=yaml
      ;;
    deployment)
      local deploy
      deploy=$(kubectl get deployments | \
        fzf --prompt="Deployment > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      kubectl get deployment "$(echo "$deploy" | awk '{print $1}')" -o yaml | bat --color=always --style=plain --paging=never --language=yaml
      ;;
    secret)
      local secret
      secret=$(kubectl get secrets | \
        fzf --prompt="Secret > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      kubectl get secret "$(echo "$secret" | awk '{print $1}')" -o yaml | bat --color=always --style=plain --paging=never --language=yaml
      ;;
  esac
}

_fe_nb() {
  local selected id
  selected=$(nb ls -a --no-color | \
    fzf --prompt="  Note > " \
        --layout=reverse \
        --height=60% \
        --preview='nb show --print $(echo {} | awk "{print \$1}" | tr -d "[]") | bat --color=always --style=plain --paging=never --language=markdown' \
        --preview-window=right:60%) || return
  id=$(echo "$selected" | awk '{print $1}' | tr -d '[]')
  nb edit "$id"
}

_fe_rm() {
  local files
  files=$(find . -type f | \
    fzf --prompt=" rm > " \
        --layout=reverse \
        --height=60% \
        --multi \
        --preview='file {} | grep -q text && bat --color=always --style=plain --paging=never {} || echo "[binary file]"' \
        --preview-window=right:60%) || return
  echo "$files" | xargs rm
}

_fe_file() {
  local file action
  action=$(printf "bat\nyank content\nyank filename\nyank relative path\nyank absolute path\nyank git remote link" | \
    fzf --prompt=" action > " \
        --layout=reverse \
        --height=30%) || return

  file=$(find . -type f | \
    fzf --prompt="󰐄 file > " \
        --layout=reverse \
        --height=60% \
        --preview='file {} | grep -q text && bat --color=always --style=plain --paging=never {} || echo "[binary file]"' \
        --preview-window=right:60%) || return

  case "$action" in
    "bat")
      bat --style=header --paging=never "$file"
      ;;
    "yank content")
      cat "$file" | pbcopy
      echo "Copied content of $file"
      ;;
    "yank filename")
      basename "$file" | tr -d '\n' | pbcopy
      echo "Copied filename: $(basename "$file")"
      ;;
    "yank relative path")
      echo -n "$file" | pbcopy
      echo "Copied relative path: $file"
      ;;
    "yank absolute path")
      realpath "$file" | tr -d '\n' | pbcopy
      echo "Copied absolute path: $(realpath "$file")"
      ;;
    "yank git remote link")
      local remote branch rel_path remote_url
      remote=$(git remote get-url origin 2>/dev/null) || { echo "No git remote found"; return 1; }
      branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
      rel_path=$(git ls-files --full-name "$file" 2>/dev/null || echo "$file")
      remote_url=$(echo "$remote" | sed 's|git@github.com:|https://github.com/|; s|\.git$||')
      local link="${remote_url}/blob/${branch}/${rel_path}"
      echo -n "$link" | pbcopy
      echo "Copied git link: $link"
      ;;
  esac
}

fe() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    cmd=$(printf "git\nkube\nnote\nrm\nfile\ndir" | \
      fzf --prompt=" fe > " --layout=reverse --height=40%) || return
  fi
  case "$cmd" in
    git)  _fe_git  ;;
    kube) _fe_kube ;;
    note) _fe_nb   ;;
    rm)   _fe_rm   ;;
    file) _fe_file ;;
    dir)  _fe_dir  ;;
  esac
}

_fe_dir() {
  local dir
  dir=$(z -l | awk '{print $2}' | \
    fzf --prompt=" dir > " \
        --layout=reverse \
        --height=40%) || return
  cd "$dir"
}

