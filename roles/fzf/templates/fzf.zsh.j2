# fzf shell integration
source <(fzf --zsh)


_find_cmd_git() {
  local cmd
  cmd=$(printf "add\nrestore\ncheckout\nshow\ndiff\nfetch" | \
    fzf --prompt=" git > " --layout=reverse --height=40%) || return
  case "$cmd" in
    add)
      local files
      files=$(git diff --name-only | \
        fzf --prompt=" git add > " \
            --layout=reverse \
            --height=60% \
            --multi \
            --preview='git diff --color=always -- {}' \
            --preview-window=right:60%) || return
      echo "git add $(echo "$files" | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
      ;;
    restore)
      local subcmd
      subcmd=$(printf "restore\nrestore --staged" | \
        fzf --prompt=" git restore > " --layout=reverse --height=40%) || return
      case "$subcmd" in
        restore)
          local files
          files=$(git diff --name-only | \
            fzf --prompt=" git restore > " \
                --layout=reverse \
                --height=60% \
                --multi \
                --preview='git diff --color=always -- {}' \
                --preview-window=right:60%) || return
          echo "git restore $(echo "$files" | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
          ;;
        "restore --staged")
          local files
          files=$(git diff --name-only --cached | \
            fzf --prompt=" git restore --staged > " \
                --layout=reverse \
                --height=60% \
                --multi \
                --preview='git diff --cached --color=always -- {}' \
                --preview-window=right:60%) || return
          echo "git restore --staged $(echo "$files" | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
          ;;
      esac
      ;;
    checkout)
      local branch
      branch=$(git branch | sed 's/^\* //; s/^  //' | \
        fzf --prompt=" git checkout > " --layout=reverse --height=40%) || return
      echo "git checkout $branch"
      ;;
    show)
      local commit
      commit=$(git log --oneline | \
        fzf --prompt=" git show > " \
            --layout=reverse \
            --height=60% \
            --preview='git show --stat --color=always {1}') || return
      echo "git show $(echo "$commit" | awk '{print $1}')"
      ;;
    diff)
      local file
      file=$(git diff --name-only | \
        fzf --prompt=" git diff > " \
            --layout=reverse \
            --height=60% \
            --preview='git diff --color=always {}') || return
      echo "git diff $file"
      ;;
    fetch)
      local remote branch
      remote=$(git remote | fzf --prompt=" git fetch > " --layout=reverse --height=40%) || return
      branch=$(git ls-remote --heads "$remote" | awk '{print $2}' | sed 's|refs/heads/||' | \
        fzf --prompt=" git fetch $remote > " --layout=reverse --height=40%) || return
      echo "git fetch $remote $branch"
      ;;
  esac
}

_find_cmd_kube() {
  local cmd
  cmd=$(printf "context\nnamespace\nget\ndescribe\nlogs" | \
    fzf --prompt="󱃾 kubectl > " --layout=reverse --height=40%) || return
  case "$cmd" in
    context)
      local current selected
      current=$(kubectl config current-context 2>/dev/null)
      selected=$(kubectl config get-contexts -o name | \
        fzf --prompt="󱃾 kubectl config use-context > " \
            --layout=reverse \
            --height=40% \
            --header="current: ${current}") || return
      echo "kubectl config use-context $selected"
      ;;
    namespace)
      local current selected
      current=$(kubectl config view --minify --output 'jsonpath={..namespace}' 2>/dev/null)
      selected=$(kubectl get namespaces -o jsonpath='{.items[*].metadata.name}' | tr ' ' '\n' | \
        fzf --prompt="󱃾 kubectl config set-context --current --namespace > " \
            --layout=reverse \
            --height=40% \
            --header="current: ${current:-default}") || return
      echo "kubectl config set-context --current --namespace=$selected"
      ;;
    get)
      local resource
      resource=$(printf "pods\nconfigmap\ndeployment\nsecret" | \
        fzf --prompt="󱃾 kubectl get > " --layout=reverse --height=40%) || return
      case "$resource" in
        pods)
          local pod
          pod=$(kubectl get pods | \
            fzf --prompt="󱃾 kubectl get pod > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl get pod $(echo "$pod" | awk '{print $1}') -o yaml | bat --color=always --style=plain --paging=never --language=yaml"
          ;;
        configmap)
          local cm
          cm=$(kubectl get configmaps | \
            fzf --prompt="󱃾 kubectl get configmap > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl get configmap $(echo "$cm" | awk '{print $1}') -o yaml | bat --color=always --style=plain --paging=never --language=yaml"
          ;;
        deployment)
          local deploy
          deploy=$(kubectl get deployments | \
            fzf --prompt="󱃾 kubectl get deployment > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl get deployment $(echo "$deploy" | awk '{print $1}') -o yaml | bat --color=always --style=plain --paging=never --language=yaml"
          ;;
        secret)
          local secret
          secret=$(kubectl get secrets | \
            fzf --prompt="󱃾 kubectl get secret > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl get secret $(echo "$secret" | awk '{print $1}') -o yaml | bat --color=always --style=plain --paging=never --language=yaml"
          ;;
      esac
      ;;
    describe)
      local resource
      resource=$(printf "pod\nconfigmap\ndeployment\nsecret" | \
        fzf --prompt="󱃾 kubectl describe > " --layout=reverse --height=40%) || return
      case "$resource" in
        pod)
          local pod
          pod=$(kubectl get pods | \
            fzf --prompt="󱃾 kubectl describe pod > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl describe pod $(echo "$pod" | awk '{print $1}')"
          ;;
        configmap)
          local cm
          cm=$(kubectl get configmaps | \
            fzf --prompt="󱃾 kubectl describe configmap > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl describe configmap $(echo "$cm" | awk '{print $1}')"
          ;;
        deployment)
          local deploy
          deploy=$(kubectl get deployments | \
            fzf --prompt="󱃾 kubectl describe deployment > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl describe deployment $(echo "$deploy" | awk '{print $1}')"
          ;;
        secret)
          local secret
          secret=$(kubectl get secrets | \
            fzf --prompt="󱃾 kubectl describe secret > " \
                --layout=reverse \
                --height=60% \
                --header-lines=1) || return
          echo "kubectl describe secret $(echo "$secret" | awk '{print $1}')"
          ;;
      esac
      ;;
    logs)
      local pod
      pod=$(kubectl get pods | \
        fzf --prompt="󱃾 kubectl logs > " \
            --layout=reverse \
            --height=60% \
            --header-lines=1) || return
      echo "kubectl logs -f $(echo "$pod" | awk '{print $1}')"
      ;;
  esac
}

_find_cmd_nb() {
  local cmd
  cmd=$(printf "show\nopen\ntodo\ndo\nundo" | \
    fzf --prompt="  nb > " --layout=reverse --height=40%) || return
  case "$cmd" in
    show|open)
      local selected id
      selected=$(nb ls -a --no-color | \
        fzf --prompt="  note > " \
            --layout=reverse \
            --height=60% \
            --preview='nb show --print $(echo {} | awk "{print \$1}" | tr -d "[]") | bat --color=always --style=plain --paging=never --language=markdown' \
            --preview-window=right:60%) || return
      id=$(echo "$selected" | awk '{print $1}' | tr -d '[]')
      echo "nb $cmd $id"
      ;;
    todo|do|undo)
      local selected id
      selected=$(nb todos --no-color | \
        fzf --prompt="  todo > " \
            --layout=reverse \
            --height=60% \
            --preview='nb show --print $(echo {} | awk "{print \$1}" | tr -d "[]") | bat --color=always --style=plain --paging=never --language=markdown' \
            --preview-window=right:60%) || return
      id=$(echo "$selected" | awk '{print $1}' | tr -d '[]')
      echo "nb $cmd $id"
      ;;
  esac
}

_find_cmd_rm() {
  local files
  files=$(find . -type f | \
    fzf --prompt=" rm > " \
        --layout=reverse \
        --height=60% \
        --multi \
        --preview='file {} | grep -q text && bat --color=always --style=plain --paging=never {} || echo "[binary file]"' \
        --preview-window=right:60%) || return
  echo "rm $(echo "$files" | tr '\n' ' ' | sed 's/[[:space:]]*$//')"
}


_find_cmd() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then
    cmd=$(printf "git\nkubectl\nnb\nrm\nz\nbat\npbcopy" | \
      fzf --prompt=" cli > " --layout=reverse --height=40%) || return
  fi
  case "$cmd" in
    git)  _find_cmd_git  ;;
    kubectl) _find_cmd_kube ;;
    nb)   _find_cmd_nb   ;;
    rm)   _find_cmd_rm   ;;
    z)      _find_cmd_z      ;;
    bat)    _find_cmd_bat    ;;
    pbcopy) _find_cmd_pbcopy ;;
  esac
}

_find_cmd_z() {
  local dir
  dir=$(z -l | awk '{print $2}' | \
    fzf --prompt=" z > " \
        --layout=reverse \
        --height=40%) || return
  echo "cd $dir"
}

_find_cmd_bat() {
  local file
  file=$(find . -type f | \
    fzf --prompt=" bat > " \
        --layout=reverse \
        --height=60% \
        --preview='file {} | grep -q text && bat --color=always --style=plain --paging=never {} || echo "[binary file]"' \
        --preview-window=right:60%) || return
  echo "bat --style=header --paging=never $file"
}

_find_cmd_pbcopy() {
  local file
  file=$(find . -type f | \
    fzf --prompt=" pbcopy > " \
        --layout=reverse \
        --height=60% \
        --preview='file {} | grep -q text && bat --color=always --style=plain --paging=never {} || echo "[binary file]"' \
        --preview-window=right:60%) || return
  echo "echo -n $file | pbcopy"
}

_find_cmd_widget() {
  zle -I
  local cmd
  cmd=$(_find_cmd) || { zle reset-prompt; return; }
  if [[ -n "$cmd" ]]; then
    BUFFER="$cmd"
    CURSOR=$#BUFFER
  fi
  zle reset-prompt
}
zle -N _find_cmd_widget
bindkey '^x^f' _find_cmd_widget

find_cmd() {
  local cmd
  cmd=$(_find_cmd "$@") || return
  [[ -n "$cmd" ]] && eval "$cmd"
}


