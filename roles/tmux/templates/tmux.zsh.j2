# Ansible roles/tmux ÔÇö status #(ÔÇĞ) helpers and zsh auto-attach.
# Tmux runs (examples):
#   zsh ~/.config/tmux/tmux.zsh cwd-pill "#{pane_current_path}"
#   zsh ~/.config/tmux/tmux.zsh git-pill "#{pane_current_path}"

_tmux_cwd_pill_for_status() {
  local p="$1"
  local h="${HOME%/}"
  if [[ -n "$h" ]]; then
    [[ "$p" == "$h" ]] && p='~'
    [[ "$p" == "$h"/* ]] && p="~/${p#"$h"/}"
  fi
  [[ -z "$p" ]] && return 0
  print -r -- "#[fg={{ theme.pink }},bg=default]¯éÂ#[fg={{ theme.bg }},bg={{ theme.pink }},bold] ´ü╝ $p #[fg={{ theme.pink }},bg=default]¯é┤"
}

_tmux_session_pill_for_status() {
  local name="$1"
  [[ -z "$name" ]] && return 0
  print -r -- "#[fg={{ theme.green }},bg=default]¯éÂ#[fg={{ theme.bg }},bg={{ theme.green }},bold] ´ê│ $name #[fg={{ theme.green }},bg=default]¯é┤"
}

_tmux_k8s_pill_for_status() {
  command -v kubectl &>/dev/null || return 0
  local ctx
  ctx=$(kubectl config current-context 2>/dev/null) || return 0
  [[ -z "$ctx" ]] && return 0
  print -r -- "#[fg={{ theme.blue }},bg=default]¯éÂ#[fg={{ theme.bg }},bg={{ theme.blue }},bold] ÔÄê $ctx #[fg={{ theme.blue }},bg=default]¯é┤"
}

_tmux_git_pill_for_status() {
  local walk="${1%/}"
  [[ -z "$walk" ]] && return 0
  local branch
  while [[ -n "$walk" ]]; do
    if git -C "$walk" rev-parse --git-dir &>/dev/null; then
      branch=$(git -C "$walk" symbolic-ref -q --short HEAD 2>/dev/null) \
        || branch=$(git -C "$walk" rev-parse --short HEAD 2>/dev/null) \
        || branch=""
      [[ -z "$branch" ]] && return 0
      print -r -- "#[fg={{ theme.orange }},bg=default]¯éÂ#[fg={{ theme.bg }},bg={{ theme.orange }},bold] ¯£Ñ $branch #[fg={{ theme.orange }},bg=default]¯é┤"
      return 0
    fi
    [[ "$walk" == */* ]] || break
    walk="${walk%/*}"
  done
  return 0
}

# When invoked directly by tmux status-bar: zsh tmux.zsh cwd-pill "ÔÇĞ"
# $# > 0 only in that case; $# == 0 when sourced from zshrc.
if [[ $# -gt 0 ]]; then
  case "$1" in
    cwd-pill)    shift; _tmux_cwd_pill_for_status "$@" ;;
    git-pill)      shift; _tmux_git_pill_for_status "$@" ;;
    k8s-pill)      _tmux_k8s_pill_for_status ;;
    session-pill)  shift; _tmux_session_pill_for_status "$@" ;;
  esac
  return 0
fi

# --- auto-attach to session "main" (create if missing) ---
# No exec: after detach the tmux client exits but this shell keeps running.
[[ "$TMUX_AUTOSTART" == "0" ]] && return
[[ -o interactive ]] || return
# Pane scrollback survives normal `clear`; also run tmux clear-history for this pane.
[[ -n "$TMUX" ]] && alias clear='command clear && tmux clear-history'
[[ -z "$TMUX" ]] || return
[[ -t 1 ]] || return
command -v tmux &>/dev/null || return

tmux new-session -As home
