[[ -z "$TMUX" ]] && tmux new-session -A -s default


_tmux_new_session() {
  read "sname?Session name: "
  [[ -n "$sname" ]] && tmux new-session -d -s "$sname"
}

_tmux_switch_session() {
  local session
  session=$(tmux ls 2>/dev/null | fzf --reverse --prompt="Session> " | cut -d: -f1) || return
  tmux switch-client -t "$session"
}

_tmux_kill_session() {
  local session
  session=$(tmux ls 2>/dev/null | fzf --reverse --prompt="Session> " | cut -d: -f1) || return
  tmux kill-session -t "$session"
}

_tmux_rename_session() {
  local session new_name
  session=$(tmux ls 2>/dev/null | fzf --reverse --prompt="Session> " | cut -d: -f1) || return
  read "new_name?New name: "
  [[ -n "$new_name" ]] && tmux rename-session -t "$session" "$new_name"
}

_tmux_new_window() {
  read "wname?Window name: "
  tmux new-window ${wname:+-n "$wname"}
}

_tmux_delete_window() {
  local window
  window=$(tmux list-windows 2>/dev/null | fzf --reverse --prompt="Window> " | cut -d: -f1) || return
  tmux kill-window -t "$window"
}

_tmux_switch_window() {
  local window
  window=$(tmux list-windows 2>/dev/null | fzf --reverse --prompt="Window> " | cut -d: -f1) || return
  tmux select-window -t "$window"
}

_tmux_rename_window() {
  read "wname?New name: "
  [[ -n "$wname" ]] && tmux rename-window "$wname"
}
