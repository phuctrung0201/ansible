# Managed by Ansible (roles/tmux). Colors from share.yml `theme` (playbook vars_files).

set -g mouse on

# Status bar — rounded pills like tmux-leader (`theme.rs`: ROUND_CAP_L \uE0B6, ROUND_CAP_R \uE0B4; Nerd Font).
set -g status on
set -g status-position bottom
# Slower refresh = less work overlapping window resize redraws; #(…) cwd runs at this interval too.
set -g status-interval 5
# Window list hidden (empty formats below); left/right pills only.
set -g status-justify left
# Bar uses terminal background (no fill); pills keep their own bg.
set -g status-style fg={{ theme.fg }},bg=default
set -g status-left-length 320
set -g status-right-length 200
# Left: cwd (green). Right: git branch pill — helpers live in tmux.zsh (cwd-status / git-pill).
set -g status-left "#[fg={{ theme.green }},bg=default]#[fg={{ theme.bg }},bg={{ theme.green }},bold]  #(zsh {{ ansible_env.HOME }}/.config/tmux/tmux.zsh cwd-status \"#{pane_current_path}\") #[fg={{ theme.green }},bg=default,nobold]"
set -g status-right "#[bg=default]#(zsh {{ ansible_env.HOME }}/.config/tmux/tmux.zsh git-pill \"#{pane_current_path}\")"

setw -g window-status-separator ""
setw -g window-status-format ''
setw -g window-status-current-format ''

set -g pane-border-style fg={{ theme.comment }}
set -g pane-active-border-style fg={{ theme.cyan }}

# Copy mode, choice trees, etc. — tmux defaults to yellow/black; tie to share.yml selection.
setw -g mode-style fg={{ theme.fg }},bg={{ theme.selection }}
setw -g menu-selected-style fg={{ theme.fg }},bg={{ theme.selection }}

# --- tmux-leader ---
# tmux-leader: #{…} in bind-key args/env-vars expand at config-parse time (not key-press
# time), so formats arrive as literals. run-shell IS evaluated at key-press time.
# Single-quoting the expanded values inside the run-shell string prevents the shell from
# interpreting $0 etc. as shell variables: tmux expands #{session_id}→$0 first, then
# the shell sees '$0' (single-quoted literal) and passes it verbatim to display-popup.

unbind-key -n F12
bind-key -n F12 run-shell "tmux display-popup -w 90% -h 30% -b rounded -S fg={{ theme.purple }} \
  -e 'LEADER_SID=#{session_id}' \
  -e 'LEADER_WID=#{window_id}' \
  -e 'LEADER_PID=#{pane_id}' \
  -E '{{ ansible_env.HOME }}/.config/tmux/tmux-leader'"
