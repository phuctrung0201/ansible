set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

set -g mode-keys vi
set -g mouse on
set -g status-position top

# Status bar
set -g status-style "bg=default,fg={{ theme.fg }}"
set -g status-left ""
set -g status-right "#[fg={{ theme.fg }},bg=default,nobold] #W #[fg={{ theme.surface0 }},bg=default]#[fg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }},nobold] #S 󰽘 #[fg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }}]#[fg={{ theme.bg }},bg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bold] #{?client_prefix,PREFIX,#{?pane_in_mode,COPY,SHELL}} "
set -g status-right-length 80
set -g window-status-format ""
set -g window-status-current-format ""

# Copy mode
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

# Pane borders
set -g pane-border-style "fg={{ theme.comment_bright }}"
set -g pane-active-border-style "fg={{ theme.purple }}"

# Tmux menu
bind -n M-\\ display-menu -T " helper " -S "fg={{ theme.purple }}" -x R -y P \
  "delete other sessions" O "kill-session -a" \
  "delete other windows"  o "kill-window -a" \
  "kill window"           x "confirm-before -p 'kill window? (y/n)' kill-window" \
  "new session"           s "new-session" \
  "new window"            w "new-window -c '#{pane_current_path}'" \
  "rename session"        R "command-prompt -I '#S' 'rename-session %%'" \
  "rename window"         r "command-prompt -I '#W' 'rename-window %%'" \
  "previous session"       P "switch-client -p" \
  "previous window"       p "previous-window" \
  "split horizontal"      h "split-window -h" \
  "split vertical"        v "split-window -v" \
  "switch session"        S "choose-tree -Zs" \
  "switch window"         W "choose-window -Z" \
  "copy mode"            c "copy-mode" \
  "copy buffer"          C "display-popup -E 'tmux capture-pane -pS - -t #{pane_id} | nvim - -c \"setlocal nomodifiable\" -c \"norm G\"'"
