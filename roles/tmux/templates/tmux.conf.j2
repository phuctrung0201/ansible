# tmux config — managed by ansible
# Theme colors come from share.yml (catppuccin mocha mix)

# Terminal / colors — truecolor (RGB) for Ghostty and other modern terminals
set -g default-terminal "tmux-256color"
set -as terminal-features ",xterm-256color:RGB,xterm-ghostty:RGB"
set -ga terminal-overrides ",xterm-ghostty:Tc"
set -g allow-passthrough on

# Prefix: Alt+p
unbind C-b
set -g prefix M-p
bind M-p send-prefix

# Behavior
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g history-limit 5000
set -g focus-events on
setw -g mode-keys vi

# Copy mode — vi-style v/y for select/yank
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"

# fzf colors (Catppuccin from share.yml) — inherited by the command palette popup.
# bg:-1 keeps the terminal's translucent background.
set-environment -g FZF_DEFAULT_OPTS "--color=fg:{{ theme.fg }},bg:-1,hl:{{ theme.orange }} --color=fg+:{{ theme.fg }}:bold,bg+:{{ theme.selection }},hl+:{{ theme.red }} --color=info:{{ theme.cyan }},prompt:{{ theme.pink }},pointer:{{ theme.yellow }} --color=marker:{{ theme.green }},spinner:{{ theme.purple }},header:{{ theme.red }}"

# Command palette — fzf picker over useful tmux commands (Alt + Space)
bind -n M-Space display-popup -E -w 50% -h 25% "~/.config/tmux/palette.sh"

# Status bar — simple colored blocks, no special glyphs required
set -g status-style "bg=default,fg={{ theme.fg }}"
set -g status-left-length 100
set -g status-right-length 100

# Left: mode (bg flips per state) > session, joined by powerline arrows (U+E0B0)
# SHELL = green, PREFIX = orange, COPY = purple
set -g status-left "#[fg={{ theme.bg }},bg=#{?client_prefix,{{ theme.orange }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bold] #{?client_prefix,PREFIX,#{?pane_in_mode,COPY,SHELL}} #[fg=#{?client_prefix,{{ theme.orange }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }},nobold]#[fg=#{?client_prefix,{{ theme.orange }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }}]  #S #[fg={{ theme.surface0 }},bg=default]"

# Window list — no bg, just bold fg for active
setw -g window-status-style "fg={{ theme.comment }},bg=default"
setw -g window-status-format " #I:#W "
setw -g window-status-current-style "fg={{ theme.fg }},bg=default,bold"
setw -g window-status-current-format " #I:#W "
setw -g window-status-separator " "

# Right: empty
set -g status-right ""

# Pane borders
set -g pane-border-style "fg={{ theme.surface0 }}"
set -g pane-active-border-style "fg={{ theme.purple }}"

# Popup borders (display-popup, e.g. command palette)
set -g popup-border-lines none

# Command bar (prefix + :) and status messages
set -g message-style "bg={{ theme.selection }},fg={{ theme.purple }}"
set -g message-command-style "bg={{ theme.selection }},fg={{ theme.purple }}"
