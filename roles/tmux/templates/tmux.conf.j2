# ─── General ──────────────────────────────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"
set -g history-limit 50000
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -sg escape-time 0
set -g focus-events on

# ─── Leader ───────────────────────────────────────────────────────────────────
unbind Space
bind Space run-shell 'rm -f /tmp/tmux-leader-action; tmux display-popup -t "#{pane_id}" -E -b none -d "#{pane_current_path}" -w 120 -h 7 "LEADER_PARENT_PANE=#{pane_id} ~/.config/tmux/leader"; [ -f /tmp/tmux-leader-action ] && { sh /tmp/tmux-leader-action; rm -f /tmp/tmux-leader-action; }; true'

# ─── Style ────────────────────────────────────────────────────────────────────
set -g status-interval 5
set -g status-style "bg=default,fg={{ theme.fg }}"

set -g status-left "#[fg={{ theme.purple }},bg=default]#[bg={{ theme.purple }},fg={{ theme.bg }},bold] #S #[fg={{ theme.purple }},bg=default] "
set -g status-left-length 30
set -g status-right ""

setw -g window-status-format "#[fg={{ theme.comment }},bg=default] #I #W "
setw -g window-status-current-format "#[fg={{ theme.blue }},bg=default]#[fg={{ theme.bg }},bg={{ theme.blue }},bold] #I #W #[fg={{ theme.blue }},bg=default]"
setw -g window-status-separator ""

set -g pane-border-style "fg={{ theme.selection }}"
set -g pane-active-border-style "fg={{ theme.blue }}"

set -g message-style "bg={{ theme.yellow }},fg={{ theme.bg }},bold"
set -g message-command-style "bg={{ theme.selection }},fg={{ theme.fg }}"
set -g mode-style "bg={{ theme.purple }},fg={{ theme.bg }},bold"
