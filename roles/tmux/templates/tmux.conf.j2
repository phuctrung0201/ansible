# ─── General ──────────────────────────────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",*:RGB"
set -g history-limit 50000
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -sg escape-time 0
set -g focus-events on

# ─── Reload ───────────────────────────────────────────────────────────────────
bind r source-file ~/.config/tmux/tmux.conf \; display "Config reloaded"

# ─── Leader ───────────────────────────────────────────────────────────────────
unbind Space
bind Space run-shell 'rm -f /tmp/tmux-leader-action; tmux display-popup -E -b none -d "#{pane_current_path}" -w 100% -h 100% "LEADER_PARENT_PANE=#{pane_id} ~/.config/tmux/leader"; [ -f /tmp/tmux-leader-action ] && sh /tmp/tmux-leader-action; rm -f /tmp/tmux-leader-action'

# ─── Style ────────────────────────────────────────────────────────────────────
{%- macro pill(color, content, bold=false) -%}
#[fg={{ color }},bg=default]#[bg={{ color }},fg={{ theme.bg }}{%- if bold -%},bold{%- endif -%}] {{ content }} #[fg={{ color }},bg=default]
{%- endmacro -%}

set -g status-position bottom
set -g status-interval 5
set -g status-style "bg=default,fg={{ theme.fg }}"

set -g status-left "{{ pill(theme.purple, ' #S', bold=true) }} {{ pill(theme.green, ' #{s|$HOME|~|:pane_current_path}') }} "
set -g status-left-length 80
set -g status-right "{{ pill(theme.pink, ' #(cd #{pane_current_path} && git rev-parse --abbrev-ref HEAD 2>/dev/null)') }} {{ pill(theme.cyan, '⎈ #(kubectl config current-context 2>/dev/null)', bold=true) }} "
set -g status-right-length 100

setw -g window-status-format "#[fg={{ theme.comment }},bg=default] #I "
setw -g window-status-current-format "{{ pill(theme.blue, '#I', bold=true) }}"
setw -g window-status-separator ""

set -g pane-border-style "fg={{ theme.selection }}"
set -g pane-active-border-style "fg={{ theme.blue }}"

set -g message-style "bg={{ theme.yellow }},fg={{ theme.bg }},bold"
set -g message-command-style "bg={{ theme.selection }},fg={{ theme.fg }}"
set -g mode-style "bg={{ theme.purple }},fg={{ theme.bg }},bold"
