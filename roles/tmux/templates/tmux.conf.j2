set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"

set -g prefix M-\\
unbind C-b
bind M-\\ send-prefix

set -g mode-keys vi
set -g mouse on
set -g status-position top

# Appearance
set -g status-style "bg=default,fg={{ theme.fg }}"
set -g status-left ""
set -g status-right "#[fg={{ theme.fg }},bg=default,nobold] #W #[fg={{ theme.surface0 }},bg=default]#[fg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }},nobold] #S 󰽘 #[fg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bg={{ theme.surface0 }}]#[fg={{ theme.bg }},bg=#{?client_prefix,{{ theme.blue }},#{?pane_in_mode,{{ theme.purple }},{{ theme.green }}}},bold] #{?client_prefix,PREFIX,#{?pane_in_mode,COPY,SHELL}} "
set -g status-right-length 80
set -g window-status-format ""
set -g window-status-current-format ""
set -g message-style "bg={{ theme.purple }},fg={{ theme.bg }}"
set -g message-command-style "bg={{ theme.purple }},fg={{ theme.bg }}"
set -g menu-selected-style "bg={{ theme.selection }},fg={{ theme.fg }},bold"
set -g menu-border-style "fg={{ theme.purple }}"
set -g popup-border-style "fg={{ theme.purple }}"
set -g mode-style "bg={{ theme.purple }},fg={{ theme.bg }},bold"
set -g pane-border-style "fg={{ theme.comment_bright }}"
set -g pane-active-border-style "fg={{ theme.purple }}"

# Copy mode
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

# Helper menu
bind \\ display-menu -T " helper " -x R -y "#{popup_pane_bottom}" \
  "add window"            a "new-window" \
  "copy buffer"           c "display-popup -E 'tmux capture-pane -pS - -t #{pane_id} | nvim - -c \"setlocal nomodifiable\" -c \"norm G\"'" \
  "delete other windows"  o "kill-window -a" \
  "rename session"        R "rename-session '#{b:pane_current_path}'" \
  "rename window"         r "display-menu -T ' rename window ' -x R -y P 'basename' b 'rename-window #{b:pane_current_path}' 'agent' a 'rename-window agent' 'git' g 'rename-window git' 'k8s' k 'rename-window k8s' 'markserv' m 'rename-window markserv' 'nvim' n 'rename-window nvim'" \
  "search window"         s "display-popup -E 'tmux list-windows -a -F \"##{session_name}:##{window_index} ##{window_name}\" | fzf --prompt \"window > \" | cut -d\" \" -f1 | xargs -I% tmux switch-client -t %'" \
  "split horizontal"      % "split-window -h -c '#{pane_current_path}'" \
  "split vertical"        '"' "split-window -v -c '#{pane_current_path}'"
