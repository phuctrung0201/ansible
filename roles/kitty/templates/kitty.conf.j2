# Ansible — Catppuccin Mocha/Macchiato mix. Mirrors roles/ghostty/templates/config.ghostty.j2.

# Font
font_family      FiraCode Nerd Font Mono
font_size        16

# Colors
background            {{ theme.bg }}
foreground            {{ theme.fg }}
selection_background  {{ theme.selection }}
selection_foreground  {{ theme.fg }}
cursor                {{ theme.cyan }}
cursor_text_color     {{ theme.bg }}

# ANSI palette (0-7)
color0  {{ theme.dark }}
color1  {{ theme.red }}
color2  {{ theme.green }}
color3  {{ theme.yellow }}
color4  {{ theme.blue }}
color5  {{ theme.pink }}
color6  {{ theme.cyan }}
color7  {{ theme.white }}
# Bright (8-15)
color8  {{ theme.comment_bright }}
color9  {{ theme.bright_red }}
color10 {{ theme.bright_green }}
color11 {{ theme.bright_yellow }}
color12 {{ theme.bright_purple }}
color13 {{ theme.bright_pink }}
color14 {{ theme.bright_cyan }}
color15 {{ theme.bright_white }}

# Cursor
cursor_shape beam

# macOS: Option sends Alt
macos_option_as_alt yes

# Window — hidden titlebar, opacity/blur matching Ghostty
background_opacity        0.65
background_blur           20
hide_window_decorations   titlebar-only
window_padding_width      0
placement_strategy        center

# Tab bar styling — keep minimal
tab_bar_style             powerline
tab_powerline_style       slanted
