# =============================================================================
# Remote control
# =============================================================================
allow_remote_control yes
listen_on            unix:/tmp/kitty

# =============================================================================
# Font
# =============================================================================
font_family FiraCode Nerd Font Mono
font_size   16.0

# =============================================================================
# Color scheme (Catppuccin Mocha)
# =============================================================================
foreground            {{ theme.fg }}
background            {{ theme.bg }}
selection_foreground  {{ theme.bg }}
selection_background  {{ theme.rosewater }}

url_color             {{ theme.rosewater }}
cursor_text_color     {{ theme.bg }}
cursor_shape          beam

# Normal colors
color0  {{ theme.dark }}
color1  {{ theme.red }}
color2  {{ theme.green }}
color3  {{ theme.yellow }}
color4  {{ theme.blue }}
color5  {{ theme.pink }}
color6  {{ theme.cyan }}
color7  {{ theme.white }}

# Bright colors
color8  {{ theme.comment_bright }}
color9  {{ theme.bright_red }}
color10 {{ theme.bright_green }}
color11 {{ theme.bright_yellow }}
color12 {{ theme.blue }}
color13 {{ theme.bright_pink }}
color14 {{ theme.bright_cyan }}
color15 {{ theme.fg }}

# =============================================================================
# Tab bar
# =============================================================================
tab_bar_style           hidden
tab_bar_background      {{ theme.bg }}
active_tab_foreground   {{ theme.bg }}
active_tab_background   {{ theme.purple }}
active_tab_font_style   bold
inactive_tab_foreground {{ theme.comment }}

# =============================================================================
# Window
# =============================================================================
hide_window_decorations titlebar-only
background_opacity      0.80
background_blur         10
enabled_layouts         tall,splits
active_border_color     {{ theme.purple }}
inactive_border_color   {{ theme.comment }}

# =============================================================================
# Scrollback
# =============================================================================
scrollback_pager nvim -c 'lua require("ansify").pager({on_finish=function() vim.cmd("normal G") end})' -

# =============================================================================
# Key mappings
# =============================================================================
map opt+space combine : goto_layout splits : launch --cwd=current --type=window --location=hsplit --bias=0 ~/.config/kitty/leader
