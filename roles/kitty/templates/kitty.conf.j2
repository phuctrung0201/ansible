# =============================================================================
# Remote control
# =============================================================================
allow_remote_control yes
listen_on            unix:/tmp/kitty

# =============================================================================
# Font
# =============================================================================
font_family FiraCode Nerd Font Mono
font_size   16.0

# =============================================================================
# Color scheme (Dracula)
# =============================================================================
foreground            {{ theme.fg }}
background            {{ theme.bg }}
selection_foreground  {{ theme.fg }}
selection_background  {{ theme.selection }}

url_color             {{ theme.pink }}
cursor_text_color     {{ theme.bg }}
cursor_shape          beam

# Normal colors
color0  {{ theme.dark }}
color1  {{ theme.red }}
color2  {{ theme.green }}
color3  {{ theme.yellow }}
color4  {{ theme.blue }}
color5  {{ theme.pink }}
color6  {{ theme.cyan }}
color7  {{ theme.white }}

# Bright colors
color8  {{ theme.comment_bright }}
color9  {{ theme.bright_red }}
color10 {{ theme.bright_green }}
color11 {{ theme.bright_yellow }}
color12 {{ theme.bright_purple }}
color13 {{ theme.bright_pink }}
color14 {{ theme.bright_cyan }}
color15 {{ theme.bright_white }}

# =============================================================================
# Tab bar
# =============================================================================
tab_bar_style           hidden
tab_bar_background      {{ theme.bg }}
active_tab_foreground   {{ theme.bg }}
active_tab_background   {{ theme.purple }}
active_tab_font_style   bold
inactive_tab_foreground {{ theme.comment_bright }}

# =============================================================================
# Window
# =============================================================================
hide_window_decorations titlebar-only
background_opacity      0.80
background_blur         10
enabled_layouts         stack
active_border_color     {{ theme.cyan }}
inactive_border_color   {{ theme.comment_bright }}

# =============================================================================
# Scrollback (nvim + ansify — TermOpen when vim.g.ansify_pager sets laststatus=0, no ruler)
# =============================================================================
scrollback_pager nvim -c 'lua require("ansify").pager({on_finish=function() vim.cmd("normal G") end})' -

# =============================================================================
# Key mappings
# =============================================================================
map cmd+w   close_window
map opt+space launch --type=overlay --cwd=current ~/.config/kitty/leader
