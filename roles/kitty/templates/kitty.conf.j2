# =============================================================================
# Remote control
# =============================================================================
allow_remote_control yes
listen_on            unix:/tmp/kitty

# =============================================================================
# Font
# =============================================================================
font_family FiraCode Nerd Font Mono
font_size   16.0

# =============================================================================
# Color scheme (Dracula)
# =============================================================================
foreground            {{ dracula.fg }}
background            {{ dracula.bg }}
selection_foreground  {{ dracula.white }}
selection_background  {{ dracula.comment }}

url_color             {{ dracula.cyan }}
cursor_text_color     {{ dracula.bg }}
cursor_shape          beam

# Normal colors
color0  {{ dracula.bg }}
color1  {{ dracula.red }}
color2  {{ dracula.green }}
color3  {{ dracula.yellow }}
color4  {{ dracula.purple }}
color5  {{ dracula.pink }}
color6  {{ dracula.cyan }}
color7  {{ dracula.fg }}

# Bright colors
color8  {{ dracula.comment }}
color9  {{ dracula.bright_red }}
color10 {{ dracula.bright_green }}
color11 {{ dracula.bright_yellow }}
color12 {{ dracula.bright_purple }}
color13 {{ dracula.bright_pink }}
color14 {{ dracula.bright_cyan }}
color15 {{ dracula.white }}

# =============================================================================
# Tab bar
# =============================================================================
tab_bar_style           hidden
tab_bar_background      {{ dracula.bg }}
active_tab_foreground   {{ dracula.bg }}
active_tab_background   {{ dracula.purple }}
active_tab_font_style   bold
inactive_tab_foreground {{ dracula.comment }}

# =============================================================================
# Window
# =============================================================================
hide_window_decorations titlebar-only
background_opacity      0.80
background_blur         10
enabled_layouts         tall
active_border_color     {{ dracula.fg }}
inactive_border_color   {{ dracula.comment }}

# =============================================================================
# Scrollback
# =============================================================================
scrollback_pager nvim -c 'lua require("ansify").pager({on_finish=function() vim.cmd("normal G") end})' -

# =============================================================================
# Key mappings
# =============================================================================
map opt+l launch --cwd=current --type=overlay ~/.config/kitty/leader
