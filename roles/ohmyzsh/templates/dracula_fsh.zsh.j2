# Dracula theme for fast-syntax-highlighting
typeset -A FAST_HIGHLIGHT_STYLES

FAST_HIGHLIGHT_STYLES[default]='none'
FAST_HIGHLIGHT_STYLES[unknown-token]='fg={{ theme.red }},bold'
FAST_HIGHLIGHT_STYLES[reserved-word]='fg={{ theme.pink }}'          # if/for/while → pink (keywords)
FAST_HIGHLIGHT_STYLES[precommand]='fg={{ theme.cyan }},underline'   # sudo/env → cyan underline
FAST_HIGHLIGHT_STYLES[subcommand]='fg={{ theme.cyan }}'
FAST_HIGHLIGHT_STYLES[commandseparator]='none'
FAST_HIGHLIGHT_STYLES[command]='fg={{ theme.cyan }}'                # commands → cyan
FAST_HIGHLIGHT_STYLES[builtin]='fg={{ theme.cyan }},bold'           # builtins → cyan bold
FAST_HIGHLIGHT_STYLES[function]='fg={{ theme.green }}'              # functions → green
FAST_HIGHLIGHT_STYLES[alias]='fg={{ theme.cyan }}'                  # aliases → cyan (act like commands)
FAST_HIGHLIGHT_STYLES[suffix-alias]='fg={{ theme.cyan }}'
FAST_HIGHLIGHT_STYLES[global-alias]='fg={{ theme.cyan }}'
FAST_HIGHLIGHT_STYLES[hashed-command]='fg={{ theme.cyan }}'
FAST_HIGHLIGHT_STYLES[autodirectory]='fg={{ theme.green }},underline'
FAST_HIGHLIGHT_STYLES[path]='fg={{ theme.fg }},underline'
FAST_HIGHLIGHT_STYLES[path_pathseparator]='fg={{ theme.comment }},underline'
FAST_HIGHLIGHT_STYLES[path_prefix]='fg={{ theme.fg }},underline'
FAST_HIGHLIGHT_STYLES[globbing]='fg={{ theme.cyan }}'
FAST_HIGHLIGHT_STYLES[history-expansion]='fg={{ theme.green }}'
FAST_HIGHLIGHT_STYLES[single-hyphen-option]='fg={{ theme.purple }}'  # flags → purple (constants)
FAST_HIGHLIGHT_STYLES[double-hyphen-option]='fg={{ theme.purple }}'
FAST_HIGHLIGHT_STYLES[back-quoted-argument]='none'
FAST_HIGHLIGHT_STYLES[single-quoted-argument]='fg={{ theme.yellow }}'  # strings → yellow
FAST_HIGHLIGHT_STYLES[double-quoted-argument]='fg={{ theme.yellow }}'
FAST_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg={{ theme.yellow }}'
FAST_HIGHLIGHT_STYLES[dollar-double-quoted-argument]='fg={{ theme.orange }}'  # vars in strings → orange
FAST_HIGHLIGHT_STYLES[back-double-quoted-argument]='fg={{ theme.orange }}'
FAST_HIGHLIGHT_STYLES[back-dollar-quoted-argument]='fg={{ theme.orange }}'
FAST_HIGHLIGHT_STYLES[assign]='none'
FAST_HIGHLIGHT_STYLES[redirection]='fg={{ theme.orange }}'
FAST_HIGHLIGHT_STYLES[comment]='fg={{ theme.comment }}'
FAST_HIGHLIGHT_STYLES[variable]='fg={{ theme.orange }}'              # variables → orange
FAST_HIGHLIGHT_STYLES[mathvar]='fg={{ theme.orange }},bold'
FAST_HIGHLIGHT_STYLES[mathnum]='fg={{ theme.purple }}'
FAST_HIGHLIGHT_STYLES[matherr]='fg={{ theme.red }}'
