# Managed by Ansible — shell styling from share.yml `theme`.
# Regenerate: ansible-playbook main.yml --tags ohmyzsh

# Suggestions: same muted tone as `theme.comment`
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#{{ theme.comment | replace('#', '') }}'

# fast-syntax-highlighting — ANSI names map to WezTerm palette (blue→purple, magenta→pink, etc.)
typeset -gA FAST_HIGHLIGHT_STYLES
FAST_HIGHLIGHT_STYLES[default]='none'
FAST_HIGHLIGHT_STYLES[unknown-token]='fg=red,bold'
FAST_HIGHLIGHT_STYLES[reserved-word]='fg=yellow,bold'
FAST_HIGHLIGHT_STYLES[alias]='fg=green,bold'
FAST_HIGHLIGHT_STYLES[builtin]='fg=cyan,bold'
FAST_HIGHLIGHT_STYLES[function]='fg=green,bold'
FAST_HIGHLIGHT_STYLES[command]='fg=blue,bold'
FAST_HIGHLIGHT_STYLES[precommand]='fg=green,bold'
FAST_HIGHLIGHT_STYLES[path]='underline,fg=cyan'
FAST_HIGHLIGHT_STYLES[path_pathseparator]='fg=12'
FAST_HIGHLIGHT_STYLES[path_prefix]='underline,fg=cyan'
FAST_HIGHLIGHT_STYLES[globbing]='fg=magenta,bold'
FAST_HIGHLIGHT_STYLES[history-expansion]='fg=green,bold'
FAST_HIGHLIGHT_STYLES[single-hyphen-option]='fg=yellow'
FAST_HIGHLIGHT_STYLES[double-hyphen-option]='fg=yellow'
FAST_HIGHLIGHT_STYLES[redirection]='fg=yellow,bold'
FAST_HIGHLIGHT_STYLES[back-quoted-argument]='fg=magenta'
FAST_HIGHLIGHT_STYLES[single-quoted-argument]='fg=green'
FAST_HIGHLIGHT_STYLES[double-quoted-argument]='fg=green'
FAST_HIGHLIGHT_STYLES[dollar-quoted-argument]='fg=green'
FAST_HIGHLIGHT_STYLES[back-dollar-quoted-argument]='fg=green'
FAST_HIGHLIGHT_STYLES[assign]='none'
FAST_HIGHLIGHT_STYLES[comment]='fg=#{{ theme.comment | replace('#', '') }}'
